  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "egxo_egocentric_data_specification",
  "description": "A machine-readable specification for egocentric robotics data, including episode semantics, RGB and IMU synchronization, annotations, quality gates, rights, provenance, and release lineage.",
  "url": "https://egxodata.com/resources/egocentric-dataset-specification-template",
  "sameAs": "https://github.com/karlpresly/egxo-egocentric-data-specification",
  "version": "1.0.3",
  "datePublished": "2026-07-23",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "creator": {
    "@type": "sc:Organization",
    "name": "EGXO Data",
    "url": "https://egxodata.com/"
  },
  "keywords": [
    "egocentric data",
    "robotics training data",
    "physical AI",
    "embodied AI",
    "RGB IMU synchronization",
    "dataset metadata",
    "dataset provenance"
  ],
  "citeAs": "EGXO Data (2026). EGXO Egocentric Data Specification and Metadata Schema, version 1.0.3.",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "schema",
      "name": "episode_json_schema",
      "description": "JSON Schema Draft 2020-12 contract.",
      "contentUrl": "https://raw.githubusercontent.com/karlpresly/egxo-egocentric-data-specification/v1.0.3/schema/egxo-egocentric-episode.schema.json",
      "encodingFormat": "application/schema+json",
      "sha256": "27a620662992193b51176f957e8ea98bce6c555a6afd8cb97565c481dfecec85"
    },
    {
      "@type": "cr:FileObject",
      "@id": "example-jsonl",
      "name": "synthetic_example_episode",
      "description": "One synthetic record with no captured participant media.",
      "contentUrl": "https://raw.githubusercontent.com/karlpresly/egxo-egocentric-data-specification/v1.0.3/data/example-episode.jsonl",
      "encodingFormat": "application/jsonl",
      "sha256": "307cc7283280675d3cff00a5e1bee7b2455b20ea400dbb78e0caa915ed888608"
    },
    {
      "@type": "cr:FileObject",
      "@id": "real-public-preview-companion",
      "name": "real_public_preview_companion",
      "description": "Measured metadata, annotations, QA, and rights boundaries for one real RGB-only EGXO public preview. The media file is not included.",
      "contentUrl": "https://raw.githubusercontent.com/karlpresly/egxo-egocentric-data-specification/v1.0.3/examples/real-public-preview-companion.json",
      "encodingFormat": "application/json",
      "sha256": "5b12afbd592576021bab6613f1fe70f0ef64c6aa7a98d9750592cc0a4ada0900"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "episode-records",
      "name": "episode_records",
      "description": "Episode-level metadata records validated by the EGXO schema.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "episode-records/schema_version",
          "name": "schema_version",
          "description": "Semantic version of the episode schema.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "example-jsonl"
            },
            "extract": {
              "jsonPath": "$.schema_version"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "episode-records/episode_id",
          "name": "episode_id",
          "description": "Stable episode identifier.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "example-jsonl"
            },
            "extract": {
              "jsonPath": "$.episode.episode_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "episode-records/task_id",
          "name": "task_id",
          "description": "Stable task definition identifier.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "example-jsonl"
            },
            "extract": {
              "jsonPath": "$.task.task_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "episode-records/acceptance_status",
          "name": "acceptance_status",
          "description": "Release disposition after QA and rights gates.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "example-jsonl"
            },
            "extract": {
              "jsonPath": "$.quality.acceptance_status"
            }
          }
        }
      ]
    }
  ]
}
